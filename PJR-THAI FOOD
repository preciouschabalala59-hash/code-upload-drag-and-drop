*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, Helvetica, sans-serif;
}

body{
    background-color:#ffffff;
    color:#333;
}

/* HEADER */

header{
    background:#8fd694;
    padding:15px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:24px;
    font-weight:bold;
    color:white;
}

nav a{
    margin-left:20px;
    text-decoration:none;
    color:white;
    font-weight:bold;
}

nav a:hover{
    text-decoration:underline;
}

/* HERO SECTION */

.hero{
    background:url("images/noodles.jpg") center/cover no-repeat;
    height:60vh;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    text-align:center;
}

.hero h1{
    background:rgba(0,0,0,0.4);
    padding:20px;
    border-radius:8px;
}

/* CONTENT */

.container{
    width:90%;
    margin:auto;
    padding:40px 0;
}

/* PRODUCTS */

.food-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
}

.food-card{
    background:white;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
    overflow:hidden;
    text-align:center;
}

.food-card img{
    width:100%;
    height:150px;
    object-fit:cover;
}

.food-card h3{
    padding:10px;
}

/* CONTACT */

.contact-info{
    line-height:2;
    font-size:18px;
}

/* FOOTER */

footer{
    background:#8fd694;
    text-align:center;
    padding:15px;
    color:white;
}

/* RESPONSIVE */

@media(max-width:768px){

    header{
        flex-direction:column;
    }

    nav{
        margin-top:10px;
    }

}
